ARG BUILDPLATFORM=linux/amd64
FROM --platform=$BUILDPLATFORM node:20-alpine@sha256:fb4cd12c85ee03686f6af5362a0b0d56d50c58a04632e6c0fb8363f609372293 AS builder

WORKDIR /build

COPY web/package.json web/package-lock.json ./
RUN npm ci

COPY web/ .
RUN npm run build

# ---- runtime ----
FROM nginx:1.27-alpine@sha256:65645c7bb6a0661892a8b03b89d0743208a18dd2f3f17a54ef4b76fb8e2f2a10

# Pull latest security patches from the base Alpine repository at build time.
RUN apk upgrade --no-cache

# Remove default config
RUN rm /etc/nginx/conf.d/default.conf

COPY --from=builder /build/dist /usr/share/nginx/html
COPY web/nginx.conf.template /etc/nginx/templates/default.conf.template

# nginx docker image auto-runs envsubst on /etc/nginx/templates/*.template
# and writes output to /etc/nginx/conf.d/ — no custom entrypoint needed.
# BFF_URL must be set at runtime, e.g. http://servicer-bff:8090

EXPOSE 8080
