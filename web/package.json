{
  "name": "servicer-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "typecheck": "vue-tsc --noEmit",
    "lint": "npm run typecheck",
    "build": "vue-tsc --noEmit && vite build",
    "build:budget": "node ./scripts/check-bundle-budget.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "test": "node ./node_modules/vitest/vitest.mjs run src/**/*.test.ts",
    "test:unit": "node ./node_modules/vitest/vitest.mjs run src/**/*.test.ts",
    "test:a11y": "node ./node_modules/@playwright/test/cli.js test tests/a11y.spec.ts"
  },
  "dependencies": {
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/theme-one-dark": "^6.1.3",
    "codemirror": "^6.0.2",
    "js-yaml": "^4.2.0",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.61.0",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vue-tsc": "^3.3.5",
    "vitest": "^4.1.9"
  }
}
