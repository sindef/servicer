FROM golang:1.25-alpine AS builder

WORKDIR /build

# Fetch deps first (layer cache)
COPY go.mod go.sum ./
RUN go mod download

# Build static binary
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
    go build -trimpath -ldflags="-s -w" -o /bff ./cmd/bff

# ---- runtime ----
FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=builder /bff /bff

EXPOSE 8090 8443
ENTRYPOINT ["/bff"]

ENTRYPOINT ["/bff"]
