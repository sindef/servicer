FROM golang:1.26-alpine@sha256:91eda9776261207ea25fd06b5b7fed8d397dd2c0a283e77f2ab6e91bfa71079d AS builder
ARG HELM_VERSION=v4.2.0
ARG TARGETOS=linux
ARG TARGETARCH=amd64

WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} \
    go build -trimpath -ldflags="-s -w" -o /manager ./cmd/manager
RUN apk add --no-cache curl tar && \
    HELM_TAR=/tmp/helm-${HELM_VERSION}-linux-${TARGETARCH}.tar.gz && \
    curl -fsSL "https://get.helm.sh/helm-${HELM_VERSION}-linux-${TARGETARCH}.tar.gz" -o "$HELM_TAR" && \
    curl -fsSL "https://get.helm.sh/helm-${HELM_VERSION}-linux-${TARGETARCH}.tar.gz.sha256sum" -o /tmp/helm.tgz.sha256sum && \
    cd /tmp && grep "helm-${HELM_VERSION}-linux-${TARGETARCH}.tar.gz" helm.tgz.sha256sum | sha256sum -c - && \
    tar -xzf "$HELM_TAR" -C /tmp && \
    mv /tmp/linux-${TARGETARCH}/helm /helm

# ---- runtime ----
FROM alpine:3.21@sha256:48b0309ca019d89d40f670aa1bc06e426dc0931948452e8491e3d65087abc07d

RUN apk add --no-cache ca-certificates git openssh-client && \
    addgroup -S servicer && \
    adduser -S -G servicer -u 65532 servicer

COPY --from=builder /manager /manager
COPY --from=builder /helm /helm

EXPOSE 8080 8081

USER 65532:65532
ENTRYPOINT ["/manager"]
